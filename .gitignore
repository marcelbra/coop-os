# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
.env
.ruff_cache/

# OS
.DS_Store
Thumbs.db

# Editors / tools
.vscode/
.idea/
.claude/*
!.claude/settings.json

